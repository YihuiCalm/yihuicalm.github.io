<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Repository Card</title>
    <style>
        .repo-card {
            border: 1px solid #ccc;
            border-radius: 5px;
            padding: 15px;
            margin: 10px 0;
            background-color: #f9f9f9;
        }
        .repo-title {
            font-size: 1.5em;
            margin: 0;
        }
        .repo-description {
            color: #555;
        }
    </style>
</head>
<body>
    <div id="repo-container"></div>
    <script>
        async function fetchRepoData() {
            const response = await fetch('https://api.github.com/repos/YihuiCalm/yihuicalm.github.io');
            const repo = await response.json();
            const repoContainer = document.getElementById('repo-container');
            const repoCard = `
                <div class="repo-card">
                    <h2 class="repo-title"><a href="${repo.html_url}">${repo.name}</a></h2>
                    <p class="repo-description">${repo.description || 'No description available.'}</p>
                </div>
            `;
            repoContainer.innerHTML = repoCard;
        }
        fetchRepoData();
    </script>
</body>
</html>
